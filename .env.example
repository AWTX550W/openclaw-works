# Android Device Automation 环境配置
# 复制此文件为 .env 并填入你的 API 密钥

# ============================================
# AI 视觉模型配置（多选一）
# ============================================

# --------------------------------------------
# 选项 1：智谱 AI GLM-4V-Flash（推荐，完全免费）
# --------------------------------------------
# 申请地址：https://open.bigmodel.cn/
# 说明：智谱 AI 推出的免费多模态模型，支持图像理解
# 免费额度：注册送 2000 万 token，实名再送 2000 万
MIDSCENE_MODEL_API_KEY=你的智谱AI_API密钥
MIDSCENE_MODEL_NAME=glm-4v-flash
MIDSCENE_MODEL_BASE_URL=https://open.bigmodel.cn/api/paas/v4
MIDSCENE_MODEL_FAMILY=glm

# --------------------------------------------
# 选项 2：字节跳动 Doubao（推荐，性价比高）
# --------------------------------------------
# 申请地址：https://www.volcengine.com/
# 说明：豆包 Seed 2.0 Lite 模型，支持视觉识别
# 免费额度：有免费试用额度
# MIDSCENE_MODEL_API_KEY=你的豆包API密钥
# MIDSCENE_MODEL_NAME=doubao-seed-2-0-lite
# MIDSCENE_MODEL_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# MIDSCENE_MODEL_FAMILY=doubao-seed

# --------------------------------------------
# 选项 3：Moonshot Kimi（多模态支持）
# --------------------------------------------
# 申请地址：https://platform.kimi.com/
# 说明：Kimi K2.6 支持视觉推理和图像理解
# 免费额度：每天有限额，需注册
# MIDSCENE_MODEL_API_KEY=你的Kimi_API密钥
# MIDSCENE_MODEL_NAME=kimi-k2-6
# MIDSCENE_MODEL_BASE_URL=https://api.kimi.ai/v1
# MIDSCENE_MODEL_FAMILY=openai-compatible

# --------------------------------------------
# 选项 4：ModelScope 魔塔社区（完全免费）
# --------------------------------------------
# 申请地址：https://modelscope.cn/
# 说明：阿里系开源模型平台，提供免费 API
# 免费额度：每天 2000 次调用（DeepSeek R1 每天 100 次）
# 注意：需要实名认证
# MIDSCENE_MODEL_API_KEY=你的ModelScope_API密钥
# MIDSCENE_MODEL_NAME=qwen-vl-plus
# MIDSCENE_MODEL_BASE_URL=https://api-inference.modelscope.cn/v1
# MIDSCENE_MODEL_FAMILY=openai-compatible

# --------------------------------------------
# 选项 5：百度千帆（企业级）
# --------------------------------------------
# 申请地址：https://qianfan.cloud.baidu.com/
# 说明：百度官方大模型平台，稳定可靠
# 免费额度：注册送一定额度
# MIDSCENE_MODEL_API_KEY=你的百度API密钥
# MIDSCENE_MODEL_NAME=ernie-vl-8k
# MIDSCENE_MODEL_BASE_URL=https://qianfan.baidubce.com/v2
# MIDSCENE_MODEL_FAMILY=baidu

# ============================================
# 可选配置
# ============================================

# 是否启用推理模式（某些模型支持）
# MIDSCENE_MODEL_REASONING_ENABLED=false

# 自定义模型参数
# MIDSCENE_MODEL_TEMPERATURE=0.7
# MIDSCENE_MODEL_MAX_TOKENS=1024
